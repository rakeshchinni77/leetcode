class Solution {
public:
    int minOperations(string s) {
        int n = s.size();
        int cnt1=0,cnt2=0;
        for(int i=0;i<n;i++) {
            int exp1 = (i%2==0)?'0':'1';
            int exp2 = (i%2==0)?'1':'0';
            if(s[i]!=exp1) cnt1++;
            if(s[i]!=exp2) cnt2++;
        }
        return min(cnt1,cnt2);
    }
};
