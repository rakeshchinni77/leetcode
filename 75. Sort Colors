class Solution {
public:
    void sortColors(vector<int>& nums) {
        vector<int>cnt(3);
        for(auto &it:nums) {
            cnt[it]++;
        }
        int idx = 0;
        for(int i=0;i<3;i++) {
            while(cnt[i]--) {
                nums[idx++] = i;
            }
        }
    }
};
