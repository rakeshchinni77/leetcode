class Solution {
public:
    vector<int> nextGreaterElement(vector<int>& nums1, vector<int>& nums2) {
        int n1 = nums1.size();
        int n2 = nums2.size();
        stack<int>st;
        unordered_map<int,int>mpp;
        for(int i=n2-1;i>=0;i--) {
            while(!st.empty() && st.top()<=nums2[i]) {
                st.pop();
            }
            mpp[nums2[i]] = st.empty() ? -1 : st.top();
            st.push(nums2[i]);
        }
        vector<int>res;
        for(auto it:nums1) {
            res.push_back(mpp[it]);
        }
        return res;
    }
};
