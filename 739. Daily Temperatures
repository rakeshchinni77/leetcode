class Solution {
public:
    vector<int> dailyTemperatures(vector<int>& temps) {
        stack<int>st;
        int n = temps.size();
        vector<int>res(n,0);
        for(int i=n-1;i>=0;i--) {
            while(!st.empty() && temps[st.top()]<=temps[i]) {
                st.pop();
            }
            if(!st.empty()) {
                res[i] = st.top()-i;
            }
            st.push(i);
        }
        return res;
    }
};
