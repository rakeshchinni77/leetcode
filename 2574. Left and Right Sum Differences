class Solution {
public:
    vector<int> leftRightDifference(vector<int>& nums) {
        int n = nums.size();
        int TotSum = 0;
        for(auto it:nums) TotSum+=it;
        int ls = 0;
        vector<int>res(n);
        for(int i=0;i<n;i++) {
            int rs = TotSum - nums[i] - ls;
            res[i] = (abs(ls-rs));
            ls+=nums[i];
        }
        return res;
    }
};
