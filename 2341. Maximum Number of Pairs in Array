class Solution {
public:
    vector<int> numberOfPairs(vector<int>& nums) {
        int n = nums.size();
        unordered_set<int>stt;
        int cnt =0;
        for(int i=0;i<n;i++){
            if(stt.count(nums[i])){
                cnt++;
                stt.erase(nums[i]);
                
            }
            else{
                stt.insert(nums[i]);
            }
        }
        return {cnt,(int)stt.size()};
    }
};
