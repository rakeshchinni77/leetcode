class Solution {
public:
    int numberOfSpecialChars(string word) {

        unordered_set<char> lower;
        unordered_set<char> upper;
        for(char ch : word) {

            if(islower(ch))
                lower.insert(ch);

            else
                upper.insert(ch);
        }

        int cnt = 0;
        for(char ch = 'a'; ch <= 'z'; ch++) {

            if(lower.count(ch) &&
               upper.count(toupper(ch))) {

                cnt++;
            }
        }

        return cnt;
    }
};
