class Solution {
public:
    bool containsNearbyDuplicate(vector<int>& nums, int k) {
        int n = nums.size();
        unordered_set<int>wind;
        int l = 0;
        for(int r=0;r<n;r++) {
            if(r-l>k) {
                wind.erase(nums[l]);
                l++;
            }
            if(wind.find(nums[r])!=wind.end()) {
                return true;
            }
            wind.insert(nums[r]);
        }
        return false;
    }
};
