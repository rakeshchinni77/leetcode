class Solution {
public:
    int lastStoneWeight(vector<int>& stones) {
        priority_queue<int>pq;
        for(auto it:stones) {
            pq.push(it);
        }
        while(pq.size()>1) {
            int firLar = pq.top();
            pq.pop();
            int secLar = pq.top();
            pq.pop();
            if(firLar!=secLar) {
                int diff = abs(firLar-secLar);
                pq.push(diff);
            }
        }
        return pq.empty()?0:pq.top();
    }
};
