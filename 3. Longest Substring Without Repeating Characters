class Solution {
public:
    int lengthOfLongestSubstring(string s) {
        int n = s.size();
        int res = 0;
        unordered_map<char,int>mpp;
        int l=0;
        for(int r=l;r<n;r++) {
            if(mpp.find(s[r])!=mpp.end()) {
                l = mpp[s[r]]+1;
            }
            mpp[s[r]] = r;
            res = max(res,r-l+1);
        }
        return res;
    }
};
