class Solution {
public:
    int n;
    vector<bool> vis;
    bool dfs(vector<int>&arr, int i) {
        if(i<0 || i>=n || vis[i])
            return false;
        if(arr[i]==0) return true;
        vis[i] = true;
        return dfs(arr,i-arr[i]) || dfs(arr,i+arr[i]);
    }
    bool canReach(vector<int>& arr, int start) {
        n = arr.size();
        vis.resize(n,false);
        return dfs(arr,start);
    }
};
