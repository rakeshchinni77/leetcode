class Solution {
public:
    void to_sort(vector<int>& people, int limit) {
        int maxele = *max_element(people.begin(),people.end());
        vector<int>count(maxele+1,0);
        for(auto it:people) count[it]++;
        int idx = 0;
        for(int i=1;i<=maxele;i++) {
            while(count[i]--) {
                people[idx++] = i;
            }
        }
    }
    int numRescueBoats(vector<int>& people, int limit) {
        int n=people.size();
        //counting sort
        to_sort(people,limit);
        int i=0,j=n-1;
        int cnt = 0;
        while(i<=j) {
            cnt++;
            if(people[j]==limit || people[i]+people[j]>limit) j--;
            else {
                i++;
                j--;
            }
        }
        return cnt;
    }
};
